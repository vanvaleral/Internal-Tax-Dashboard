# First-layer login selectors from current Mylmats V2 login page
ATTENDANCE_USERNAME_SELECTOR=input[placeholder="Enter your email"] || input[type="email"] || input[name="email"]
ATTENDANCE_PASSWORD_SELECTOR=input[placeholder="Enter your password"] || input[type="password"] || input[name="password"]
ATTENDANCE_SUBMIT_SELECTOR=button:has-text("Log In") || button[type="submit"]

# Inferred from your description: second layer asks for attendance password
ATTENDANCE_SECOND_PASSWORD_SELECTOR=input[type="password"] || input[placeholder*="password" i] || input[name="password"]
ATTENDANCE_SECOND_SUBMIT_SELECTOR=button[type="submit"] || button:has-text("Attend") || button:has-text("Check In") || button:has-text("Submit") || button:has-text("Log In")

# Inferred from the success screenshot: attendance dashboard / Absensi page
ATTENDANCE_SUCCESS_SELECTOR=text=Absensi || th:has-text("Check In") || th:has-text("Periode") || text=Total Work Time
